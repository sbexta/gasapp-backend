{
  "expo": {
    "name": "GasApp",
    "slug": "gasapp-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "gasapp",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sbexta.gasapp"
    },
    "android": {
      "package": "com.sbexta.gasapp",
      "adaptiveIcon": {
        "backgroundColor": "#1D4ED8",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1D4ED8"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
